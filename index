<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>MDD Learning Portal</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js"></script>

<style>

body{
font-family:Inter;
margin:0;
background:#f4f6fb;
}

header{
background:#0d1b38;
color:white;
padding:20px;
font-size:22px;
font-weight:600;
}

.container{
max-width:1200px;
margin:auto;
padding:30px;
}

.card{
background:white;
padding:25px;
border-radius:10px;
margin-bottom:25px;
box-shadow:0 5px 15px rgba(0,0,0,0.08);
}

h2{
margin-top:0;
}

input[type=file],input[type=text]{
width:100%;
padding:10px;
margin:10px 0;
}

button{
background:#0d1b38;
color:white;
border:none;
padding:10px 18px;
border-radius:6px;
cursor:pointer;
}

button:hover{
opacity:0.9;
}

.material{
padding:10px;
border-bottom:1px solid #eee;
}

iframe{
border:none;
margin-top:15px;
border-radius:6px;
}

.download{
display:inline-block;
margin-top:10px;
background:#e9a22b;
color:black;
padding:8px 14px;
border-radius:6px;
text-decoration:none;
}

.blog{
border:1px solid #ddd;
padding:15px;
margin-top:20px;
border-radius:6px;
}

</style>
</head>

<body>

<header>
📚 MDD Learning Portal
</header>

<div class="container">

<!-- PDF VIEWER -->

<div class="card">

<h2>📄 Upload & View PDF</h2>

<input type="file" id="pdfUpload" accept="application/pdf">

<div id="viewer"></div>

<a id="downloadBtn" class="download" style="display:none">Download PDF</a>

</div>


<!-- STUDY MATERIAL -->

<div class="card">

<h2>📚 Study Material</h2>

<input type="file" id="studyUpload" accept="application/pdf">

<div id="studyList"></div>

</div>


<!-- BLOG SYSTEM -->

<div class="card">

<h2>📝 Blog Editor</h2>

<input type="text" id="blogTitle" placeholder="Enter blog title">

<textarea id="blogEditor"></textarea>

<br><br>

<button onclick="publishBlog()">Publish Blog</button>

<div id="blogPosts"></div>

</div>

</div>


<script>

/* PDF VIEW SYSTEM */

document.getElementById("pdfUpload").addEventListener("change",function(e){

let file=e.target.files[0];

if(!file) return;

let url=URL.createObjectURL(file);

document.getElementById("viewer").innerHTML=
`<iframe src="${url}" width="100%" height="500"></iframe>`;

let btn=document.getElementById("downloadBtn");

btn.href=url;
btn.download=file.name;
btn.style.display="inline-block";

});


/* STUDY MATERIAL SYSTEM */

let list=document.getElementById("studyList");

document.getElementById("studyUpload").addEventListener("change",function(e){

let file=e.target.files[0];

if(!file) return;

let url=URL.createObjectURL(file);

let div=document.createElement("div");

div.className="material";

div.innerHTML=`
<strong>${file.name}</strong>
<br>
<a href="${url}" target="_blank">View</a> |
<a href="${url}" download="${file.name}">Download</a>
`;

list.appendChild(div);

});


/* BLOG EDITOR */

tinymce.init({

selector:'#blogEditor',

height:400,

plugins:
'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',

toolbar:
'undo redo | blocks | fontfamily fontsize | bold italic underline strikethrough | alignleft aligncenter alignright alignjustify | numlist bullist | forecolor backcolor | table image media link | removeformat | code fullscreen',

menubar:'file edit view insert format tools table help',

branding:false

});


function publishBlog(){

let title=document.getElementById("blogTitle").value;

let content=tinymce.get("blogEditor").getContent();

if(!title || !content){

alert("Please add title and content");

return;

}

let post=document.createElement("div");

post.className="blog";

post.innerHTML=`
<h3>${title}</h3>
${content}
<hr>
`;

document.getElementById("blogPosts").prepend(post);

document.getElementById("blogTitle").value="";

tinymce.get("blogEditor").setContent("");

}

</script>

</body>
</html>
